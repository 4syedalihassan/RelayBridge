{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "enabled": true
  },
  "versioning": {
    "enabled": true,
    "git": {
      "autoStage": true,
      "commitConvention": "conventional"
    }
  },
  "logging": {
    "enabled": true,
    "dir": ".opencode/logs",
    "level": "info",
    "retention": {
      "maxFiles": 10,
      "maxSizeMb": 50
    }
  },
  "plugin": [
    "code-simplifier",
    "oh-my-opencode"
  ]
}
