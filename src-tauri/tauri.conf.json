{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "RelayBridge",
  "version": "0.1.0",
  "identifier": "com.relaybridge.app",
  "build": {
    "frontendDist": "../packages/desktop-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix packages/desktop-ui",
    "beforeBuildCommand": "npm run build --prefix packages/desktop-ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RelayBridge",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "RelayBridge",
        "width": 500,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
